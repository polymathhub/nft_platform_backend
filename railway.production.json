{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile",
    "buildCommand": "docker build -f Dockerfile --build-arg ENVIRONMENT=production -t nft-platform:latest .",
    "buildContext": "."
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "startupProbe": {
      "type": "HTTP",
      "httpPath": "/health",
      "initialDelaySeconds": 60,
      "periodSeconds": 10,
      "timeoutSeconds": 5,
      "failureThreshold": 5,
      "successThreshold": 1
    },
    "livenessProbe": {
      "type": "HTTP",
      "httpPath": "/health",
      "initialDelaySeconds": 30,
      "periodSeconds": 10,
      "timeoutSeconds": 5,
      "failureThreshold": 3,
      "successThreshold": 1
    },
    "readinessProbe": {
      "type": "HTTP",
      "httpPath": "/health",
      "initialDelaySeconds": 20,
      "periodSeconds": 5,
      "timeoutSeconds": 3,
      "failureThreshold": 2,
      "successThreshold": 1
    }
  },
  "variables": {
    "ENVIRONMENT": "production",
    "DEBUG": "False",
    "LOG_LEVEL": "info",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "WORKERS": "4"
  },
  "environment": {
    "DATABASE_URL": "${{ Postgres.DATABASE_URL }}",
    "ENVIRONMENT": "production",
    "DEBUG": "False",
    "LOG_LEVEL": "info",
    "JWT_SECRET_KEY": "${{ Railway.Secret.JWT_SECRET_KEY }}",
    "MNEMONIC_ENCRYPTION_KEY": "${{ Railway.Secret.MNEMONIC_ENCRYPTION_KEY }}",
    "TELEGRAM_BOT_TOKEN": "${{ Railway.Secret.TELEGRAM_BOT_TOKEN }}",
    "TELEGRAM_WEBHOOK_URL": "${{ Railway.Env.RAILWAY_PUBLIC_DOMAIN }}/api/v1/telegram/webhook",
    "TELEGRAM_AUTO_SETUP_WEBHOOK": "True",
    "TELEGRAM_WEBHOOK_SECRET": "${{ Railway.Secret.TELEGRAM_WEBHOOK_SECRET }}",
    "TELEGRAM_WEBAPP_URL": "https://${{ Railway.Env.RAILWAY_PUBLIC_DOMAIN }}/webapp/",
    "APP_URL": "https://${{ Railway.Env.RAILWAY_PUBLIC_DOMAIN }}"
  },
  "services": {
    "postgres": {
      "type": "postgres",
      "version": "15",
      "environment": {
        "POSTGRES_USER": "nft_user",
        "POSTGRES_DB": "nft_platform",
        "POSTGRES_PASSWORD": "${{ Railway.Secret.POSTGRES_PASSWORD }}"
      }
    }
  },
  "plugins": [
    {
      "source": "github.com/railwayapp/plugins",
      "name": "postgres"
    }
  ]
}
